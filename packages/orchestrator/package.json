{
  "name": "@pixler/orchestrator",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "server": ["./dist/server.d.ts"]
    }
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "typescript": "^5.8.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  }
}
