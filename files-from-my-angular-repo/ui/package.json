{
  "name": "@lazar/ui",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.ts",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./icons": {
      "default": "./src/icons-public-api.ts"
    },
    "./table-data": {
      "default": "./src/features/data-table/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch & ng run ui:storybook",
    "clean": "rimraf dist",
    "storybook": "ng run ui:storybook",
    "build-storybook": "ng run ui:build-storybook",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-angular": "^21.0.0",
    "embla-carousel-auto-height": "^8.6.0",
    "embla-carousel-auto-scroll": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-class-names": "^8.6.0",
    "embla-carousel-fade": "^8.6.0",
    "embla-carousel-wheel-gestures": "^8.1.0",
    "gsap": "^3.14.2",
    "lucide-angular": "^0.575.0",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "@angular/cdk": "^21.1.4",
    "@angular/common": "^21.1.4",
    "@angular/core": "^21.1.4",
    "@angular/forms": "^21.1.4",
    "@angular/router": "^21.1.4",
    "@lazar/ui-styles": "workspace:*",
    "rxjs": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@lazar/ui-styles": {
      "optional": true
    }
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.1.4",
    "@angular/animations": "^21.1.5",
    "@angular/cdk": "^21.1.5",
    "@angular/cli": "^21.1.4",
    "@angular/common": "^21.1.5",
    "@angular/compiler": "^21.1.5",
    "@angular/compiler-cli": "^21.1.5",
    "@angular/core": "^21.1.5",
    "@angular/forms": "^21.1.5",
    "@angular/platform-browser": "^21.1.5",
    "@angular/platform-browser-dynamic": "^21.1.5",
    "@angular/router": "^21.1.5",
    "@compodoc/compodoc": "^1.2.1",
    "@lazar/config-eslint": "workspace:*",
    "@lazar/config-typescript": "workspace:*",
    "@lazar/ui-styles": "workspace:*",
    "@storybook/addon-docs": "^10.2.10",
    "@storybook/addon-themes": "^10.2.13",
    "@storybook/angular": "^10.2.10",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/react": "^19.0.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "react": "^19.0.0",
    "rimraf": "^5.0.10",
    "rxjs": "^7.8.2",
    "storybook": "^10.2.10",
    "tailwindcss": "^4.2.0",
    "tslib": "^2.8.1",
    "typescript": "~5.9.3",
    "zone.js": "~0.16.1"
  }
}
