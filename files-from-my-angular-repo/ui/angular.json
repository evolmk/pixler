{
  "$schema": "../../node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "ui": {
      "projectType": "library",
      "root": "",
      "sourceRoot": "src",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/storybook-build",
            "index": "storybook-host/index.html",
            "browser": "storybook-host/main.ts",
            "tsConfig": "tsconfig.json",
            "inlineStyleLanguage": "css",
            "polyfills": [],
            "assets": [],
            "styles": ["storybook-host/styles.css"],
            "scripts": []
          }
        },
        "storybook-build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/storybook-build",
            "index": "storybook-host/index.html",
            "browser": "storybook-host/main.ts",
            "tsConfig": ".storybook/tsconfig.json",
            "inlineStyleLanguage": "css",
            "polyfills": [],
            "assets": [],
            "styles": ["storybook-host/styles.css"],
            "scripts": []
          }
        },
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "port": 6006,
            "configDir": ".storybook",
            "browserTarget": "ui:storybook-build"
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "outputDir": "storybook-static",
            "configDir": ".storybook",
            "browserTarget": "ui:storybook-build"
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
